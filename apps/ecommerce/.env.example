# Ecommerce App Environment Variables

# ==============================================================================
# Prisma & Database
# ==============================================================================
# 1. Create a free Postgres database on Neon (neon.tech)
# 2. Copy the "Connection string" (pooled or unpooled). 
# 3. Paste it below
DATABASE_URL="postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require"

# To sync the schema with your Neon DB, run:
# pnpm --filter @repo/db db:push   OR   pnpm --filter @repo/db db:migrate

# ==============================================================================
# Clerk Authentication
# ==============================================================================
# Create a free account at clerk.dev and create a new project.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# ==============================================================================
# Stripe
# ==============================================================================
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# -- STRIPE WEBHOOK TESTING --
# 1. Install Stripe CLI
# 2. Run: stripe listen --forward-to localhost:3003/api/webhooks/stripe
# 3. Copy the webhook signing secret from the terminal output and paste below
STRIPE_WEBHOOK_SECRET="whsec_..."

# ==============================================================================
# Resend Emails
# ==============================================================================
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="onboarding@resend.dev" # Change in production to e.g. orders@yourdomain.com
